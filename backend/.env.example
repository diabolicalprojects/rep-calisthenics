# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# URL de conexión a PostgreSQL. Formato: postgres://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgres://gym_user:your_db_password@localhost:5432/gym_db

# ─── AUTENTICACIÓN ────────────────────────────────────────────────────────────
# Secreto para firmar tokens JWT. Debe ser una cadena larga y aleatoria (mínimo 32 caracteres).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_SECRETO_LARGO_Y_ALEATORIO

# ─── CREDENCIALES INICIALES DE SISTEMA ───────────────────────────────────────
# Estas contraseñas se usan SOLO en el primer arranque del servidor para crear
# los usuarios de sistema en la base de datos. Cámbialas desde la UI después.
# IMPORTANTE: No usar la misma contraseña en ambos usuarios.
INITIAL_ADMIN_PASSWORD=REEMPLAZAR_CONTRASENA_ADMIN
INITIAL_DEV_PASSWORD=REEMPLAZAR_CONTRASENA_DEVELOPER

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
# Puerto del servidor backend (por defecto 4000)
PORT=4000
